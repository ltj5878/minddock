# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local database (default is PostgreSQL because Phase 3 will use pgvector)
DATABASE_URL=postgresql+psycopg://lvtongjie@localhost:5432/minddock
# MySQL alternative:
# DATABASE_URL=mysql+pymysql://root@localhost:3306/minddock

# OpenAI
OPENAI_API_KEY=your-openai-key

# Claude
ANTHROPIC_API_KEY=your-anthropic-key

# Gemini
GOOGLE_API_KEY=your-google-key

# Notion
NOTION_INTEGRATION_TOKEN=your-notion-token
